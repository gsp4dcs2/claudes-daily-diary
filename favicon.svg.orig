<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 72 72">
  <!-- Background -->
  <circle cx="36" cy="36" r="36" fill="#2D1B0E"/>
  <!-- Logo mark -->
  <g transform="translate(36,36)">
    <!-- Central dot -->
    <circle r="4" fill="#F4A07D"/>
    <!-- Cardinal rays -->
    <rect x="-2" y="-26" width="4" height="14" rx="2" fill="#E8734A" opacity="0.9"/>
    <rect x="-2" y="12"  width="4" height="14" rx="2" fill="#E8734A" opacity="0.9"/>
    <rect x="12" y="-2"  width="14" height="4"  rx="2" fill="#E8734A" opacity="0.9"/>
    <rect x="-26" y="-2" width="14" height="4"  rx="2" fill="#E8734A" opacity="0.9"/>
    <!-- Diagonal rays -->
    <rect x="7.5"  y="-20" width="4" height="14" rx="2" fill="#F4A07D" opacity="0.7" transform="rotate(45 7.5 -20)"/>
    <rect x="7.5"  y="6"   width="4" height="14" rx="2" fill="#F4A07D" opacity="0.7" transform="rotate(-45 7.5 6)"/>
    <rect x="-11.5" y="-20" width="4" height="14" rx="2" fill="#F4A07D" opacity="0.7" transform="rotate(-45 -11.5 -20)"/>
    <rect x="-11.5" y="6"   width="4" height="14" rx="2" fill="#F4A07D" opacity="0.7" transform="rotate(45 -11.5 6)"/>
  </g>
</svg>
