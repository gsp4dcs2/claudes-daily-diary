 Phase 3 — Add search logic (inline <script>)

 After the SEARCH_INDEX declaration, add:

 (function () {
   const input   = document.getElementById('diary-search');
   const items   = Array.from(document.querySelectorAll('.article-list li'));
   const noRes   = document.getElementById('search-no-results');
   const echo    = document.getElementById('search-query-echo');

   input.addEventListener('input', function () {
     const q = this.value.trim().toLowerCase();

     // Remove any previous snippets
     items.forEach(li => {
       const s = li.querySelector('.search-snippet');
       if (s) s.remove();
     });

     if (!q) {
       items.forEach(li => li.hidden = false);
       noRes.hidden = true;
       return;
     }

     let matched = 0;
     items.forEach(li => {
       // Find matching index entry by URL
       const href = li.querySelector('a').getAttribute('href');
       const entry = SEARCH_INDEX.find(e => e.url === href);
       const haystack = entry ? (entry.title + ' ' + entry.text).toLowerCase() : '';
       const hit = haystack.includes(q);
       li.hidden = !hit;

       if (hit && entry) {
         matched++;
         // Build a short snippet around the first match in body text
         const idx = entry.text.toLowerCase().indexOf(q);
         if (idx !== -1) {
           const start = Math.max(0, idx - 40);
           const end   = Math.min(entry.text.length, idx + q.length + 60);
           const snip  = (start > 0 ? '…' : '') +
                         entry.text.slice(start, end) +
                         (end < entry.text.length ? '…' : '');
           const span = document.createElement('span');
           span.className = 'search-snippet';
           span.textContent = snip;
           li.appendChild(span);
         }
       }
     });

     echo.textContent = this.value.trim();
     noRes.hidden = matched > 0;
   });
 })();

